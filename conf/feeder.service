[Unit]
Description=HFT Market Data Feeder
After=network.target

[Service]
Type=simple
User=hft-user
Group=hft-group
WorkingDirectory=/opt/hft
EnvironmentFile=/opt/hft/conf/ipc.env
ExecStart=/opt/hft/bin/feeder/feeder
Restart=always
RestartSec=60
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hft-feeder
LimitCORE=infinity
LimitMEMLOCK=infinity

[Install]
WantedBy=multi-user.target
